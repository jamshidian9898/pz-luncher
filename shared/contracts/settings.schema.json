{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pzlauncher.local/schemas/settings.schema.json",
  "title": "LauncherSettings",
  "description": "RFC-0036 — persisted launcher configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "gamePath": { "type": "string", "description": "Project Zomboid install (PZ_PATH)" },
    "backendUrl": { "type": "string", "description": "Backend API base URL (v2.0.0 single control plane)" },
    "cachePath": { "type": "string" },
    "profilesPath": { "type": "string" },
    "concurrentDownloads": { "type": "integer", "minimum": 1, "maximum": 10, "default": 3 },
    "bandwidthLimitMbps": { "type": "integer", "minimum": 0, "default": 0 },
    "verifyChecksum": { "type": "boolean", "default": true }
  }
}
