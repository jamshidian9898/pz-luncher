# PZ Launcher Configuration Template
# Copy this file to .env and fill in your values

# ==================== BACKEND ====================

# Backend API URL (for launcher to connect)
PZG_BACKEND_URL=http://localhost:8080

# Backend port (for server to listen)
PZG_BACKEND_PORT=8080

# Data directory for backend
PZG_DATA_DIR=./data

# ==================== AGENT ====================

# Agent registration token (get from backend)
PZG_AGENT_TOKEN=your-agent-token-here

# Agent server ID (unique name for this agent node)
PZG_AGENT_SERVER_ID=pz-srv-1

# Agent backend URL
PZG_AGENT_BACKEND_URL=http://localhost:8080

# Agent content path (where PZ server files are)
PZG_AGENT_CONTENT_PATH=C:/Program Files (x86)/Steam/steamapps/common/ProjectZomboid

# ==================== LAUNCHER ====================

# Game installation path
PZG_GAME_PATH=C:/Program Files (x86)/Steam/steamapps/common/ProjectZomboid

# Cache directory for downloads
PZG_CACHE_PATH=./cache

# Profiles directory (user saves)
PZG_PROFILES_PATH=./profiles

# Custom launch options (passed to game executable)
PZG_LAUNCH_OPTIONS=-debug -adminpassword secret123

# ==================== DEV ENVIRONMENT ====================

# Dev API port (for local testing)
PZG_DEV_API_PORT=8765

# Enable debug logging
PZG_DEBUG=true

# Log level: debug, info, warn, error
PZG_LOG_LEVEL=debug

# Workspace root (auto-detected if not set)
PZG_WORKSPACE_ROOT=.

# ==================== VAGRANT VM ====================

# VM Memory (MB)
VAGRANT_MEMORY=6144

# VM CPUs
VAGRANT_CPUS=4

# VM Name
VAGRANT_VM_NAME=PZ-Launcher-Dev

# Synced folder path (project location in VM)
VAGRANT_SYNC_FOLDER=C:/Users/vagrant/project

# ==================== BUILD ====================

# Version string
VERSION=beta-1

# Build output directory
DIST_DIR=dist

# Application name
APP_NAME=pz-launcher
